generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VENDOR
  ADMIN
}

model User {
  id String @id @default(uuid())

  name String

  email String @unique

  password String

  role  Role   @default(USER)
  phone String @unique

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
