generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VENDOR
  ADMIN
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(USER)
  phone      String?  @unique
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendor        Vendor?
  bookings      Booking[]
  reviews       Review[]
  budgets       Budget[]
  timelines     Timeline[]
  checklists    Checklist[]
  notifications Notification[]
  guests        Guest[]
  chatMessages  ChatMessage[]
  leads Lead[]
}

model Vendor {
  id           String  @id @default(uuid())
  businessName String
  description  String?
  address      String?
  logoUrl      String?
  coverImage   String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  packages  Package[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  gallery   VendorGallery[]

  bookings Booking[]
}

model VendorGallery {
  id       String @id @default(uuid())
  imageUrl String

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[] 
  reviews   Review[]
  leads Lead[]
}

model Category {
  id    String  @id @default(uuid())
  name  String  @unique
  image String?

  vendors   Vendor[]
  packages  Package[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Package {
  id          String   @id @default(uuid())
  title       String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  inclusions  String[]

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  bookings  Booking[]
  reviews   Review[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  leads Lead[]
}

enum BookingStatus {
  PENDING
  ACCEPTED
  CONFIRMED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Booking {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  packageId String
  package   Package @relation(fields: [packageId], references: [id])

  eventDate          DateTime
  status             BookingStatus @default(PENDING)
  totalAmount        Decimal       @db.Decimal(10, 2)
  notes              String?
  cancellationReason String?

  paymentStatus PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review Review? 
}

model Review {
  id      String  @id @default(uuid())
  rating  Int     @default(5)
  comment String?
  vendorReply String?
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  packageId String
  package   Package @relation(fields: [packageId], references: [id])

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  bookingId String? @unique   // optional: enforce "only after completed booking"
  booking   Booking? @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}

enum GuestStatus {
  INVITED
  CONFIRMED
  DECLINED
}

model Guest {
  id     String      @id @default(uuid())
  name   String
  phone  String?
  email  String?
  status GuestStatus @default(INVITED)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Budget {
  id          String   @id @default(uuid())
  totalBudget Decimal  @db.Decimal(10, 2)

   userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Expense {
  id       String  @id @default(uuid())
  title    String
  category String
  amount   Decimal @db.Decimal(10, 2)
  note     String?
  date     DateTime @default(now())

  budgetId String
  budget   Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TimelineStatus {
  PENDING
  DONE
}

model Timeline {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  title       String
  date        DateTime
  description String?
  status      TimelineStatus @default(PENDING)

  createdAt DateTime @default(now())
}

model Checklist {
  id     String  @id @default(uuid())
  task   String
  isDone Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id      String  @id @default(uuid())
  title   String
  message String
  isRead  Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

enum ChatRole {
  USER
  ASSISTANT
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      ChatRole
  content   String
  createdAt DateTime @default(now())
}
enum LeadStatus {
  PENDING
  RESPONDED
  CONVERTED
  CLOSED
}

model Lead {
  id         String    @id @default(uuid())
  name       String
  email      String
  phone      String?
  eventDate  DateTime
  guestCount Int
  message    String
  status     LeadStatus @default(PENDING)
  vendorReply String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  packageId String?
  package   Package? @relation(fields: [packageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model SiteContent {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}
